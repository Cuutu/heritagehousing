# =============================================================================
# Database (Supabase + Prisma)
# =============================================================================
#
# En Vercel (serverless) NO uses la conexión "Direct" (db.xxx.supabase.co:5432).
# Esa URL suele dar "Can't reach database server" porque el runtime de Vercel
# no alcanza bien el host directo / IPv6.
#
# - DATABASE_URL → Pooler en modo Transaction, puerto 6543 (obligatorio en prod)
#   Supabase: Project Settings → Database → Connection string →
#   "Transaction pooler" / URI con pooler y ?pgbouncer=true
#
# - DIRECT_URL → Conexión directa db.<ref>.supabase.co:5432
#   Solo para `prisma migrate` / `db push` desde tu máquina o CI (no para Vercel runtime)
#
# Ejemplo local (ambas iguales está bien en dev):
DATABASE_URL="postgresql://user:password@localhost:5432/heritagehousing"
DIRECT_URL="postgresql://user:password@localhost:5432/heritagehousing"
#
# Ejemplo Supabase (reemplazá user, password, host del pooler de tu proyecto):
# DATABASE_URL="postgresql://postgres.xxxxx:[PASSWORD]@aws-0-us-east-2.pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL="postgresql://postgres:[PASSWORD]@db.xxxxx.supabase.co:5432/postgres"

# Clerk Auth
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_xxxxx"
CLERK_SECRET_KEY="sk_test_xxxxx"
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/admin"

# Stripe
STRIPE_SECRET_KEY="sk_test_xxxxx"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_xxxxx"
STRIPE_WEBHOOK_SECRET="whsec_xxxxx"

# Resend Email
RESEND_API_KEY="re_xxxxx"
RESEND_FROM="hola@heritagehousing.cl"
# Optional: internal notifications (leads, etc.)
RESEND_NOTIFY_TO="contacto@heritagehousing.cl"

# WhatsApp (Chile, formato sin + ni espacios)
NEXT_PUBLIC_WHATSAPP_NUMBER="56912345678"

# Cron Security
CRON_SECRET="your-cron-secret-here"

# App URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"
