generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum ReservationSource {
  DIRECT
  AIRBNB
  BOOKING
  MANUAL
}

enum PaymentStatus {
  PENDING
  PAID
  REFUNDED
  CANCELLED
}

enum ReservationLifecycleStatus {
  CONFIRMED
  PENDING
  CANCELLED
  COMPLETED
}

enum CleaningStatus {
  PENDING
  NOTIFIED
  CONFIRMED
  IN_PROGRESS
  DONE
}

model Property {
  id             String        @id @default(cuid())
  slug           String        @unique
  name           String
  description    String
  location       String
  /// Dirección completa (calle, número) para mostrar en mapa y buscadores
  mapAddress     String?
  /// Link compartido de Google Maps (place, maps, goo.gl); se usan para extraer coordenadas y "Abrir en Maps"
  googleMapsLink String?
  latitude       Float?
  longitude      Float?
  pricePerNight  Decimal       @db.Decimal(10, 2)
  maxGuests      Int
  bedrooms       Int
  bathrooms      Int
  images         String[]
  amenities      String[]
  airbnbIcalUrl  String?
  bookingIcalUrl String?
  isActive       Boolean       @default(true)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  reservations   Reservation[]
  blockedDates   BlockedDate[]
  propertyImages PropertyImage[] @relation("PropertyGallery")
  cleaningStaff  CleaningStaff[] @relation("StaffProperties")
  cleaningAssignments CleaningAssignment[]

  @@index([isActive])
  @@index([slug])
}

model PropertyImage {
  id         String   @id @default(cuid())
  propertyId String
  url        String
  order      Int      @default(0)
  createdAt  DateTime @default(now())
  property   Property @relation("PropertyGallery", fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
}

model Reservation {
  id                String                     @id @default(cuid())
  propertyId        String
  property          Property                   @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  source            ReservationSource          @default(DIRECT)
  checkIn           DateTime                   @db.Date
  checkOut          DateTime                   @db.Date
  guestName         String
  guestEmail        String
  guestPhone        String?
  guestCount        Int                        @default(1)
  totalPrice        Decimal                    @db.Decimal(10, 2)
  paymentStatus     PaymentStatus              @default(PENDING)
  lifecycleStatus   ReservationLifecycleStatus @default(PENDING)
  stripeId          String?
  externalId        String?
  notes             String?
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt
  cleaningAssignments CleaningAssignment[]

  @@index([propertyId])
  @@index([propertyId, checkIn, checkOut])
  @@index([checkIn, checkOut])
  @@index([paymentStatus])
  @@index([source])
  @@index([lifecycleStatus])
}

model BlockedDate {
  id         String   @id @default(cuid())
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  date       DateTime @db.Date
  source     String
  createdAt  DateTime @default(now())

  @@unique([propertyId, date])
  @@index([propertyId])
  @@index([propertyId, date])
}

model Project {
  id           String   @id @default(cuid())
  slug         String   @unique
  title        String
  description  String
  category     String
  area         Int?
  duration     Int?
  beforeImages String[]
  afterImages  String[]
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  projectImages ProjectImage[] @relation("ProjectGallery")

  @@index([isActive])
  @@index([category])
}

model ProjectImage {
  id        String   @id @default(cuid())
  projectId String
  url       String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  project   Project  @relation("ProjectGallery", fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model Lead {
  id          String   @id @default(cuid())
  name        String
  email       String
  phone       String?
  projectType String
  message     String
  createdAt   DateTime @default(now())

  @@index([createdAt])
}

model Post {
  id          String    @id @default(cuid())
  slug        String    @unique
  title       String
  excerpt     String
  content     String    @db.Text
  coverImage  String?
  published   Boolean   @default(false)
  publishedAt DateTime?
  author      String    @default("Heritage Housing")
  tags        String[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  postImages  PostImage[] @relation("PostGallery")

  @@index([published, publishedAt])
  @@index([slug])
}

model PostImage {
  id        String   @id @default(cuid())
  postId    String
  url       String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  post      Post     @relation("PostGallery", fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
}

model CleaningStaff {
  id          String               @id @default(cuid())
  name        String
  phone       String
  active      Boolean              @default(true)
  createdAt   DateTime             @default(now())
  assignments CleaningAssignment[]
  properties  Property[]           @relation("StaffProperties")
}

model CleaningAssignment {
  id            String         @id @default(cuid())
  reservationId String
  staffId       String
  propertyId    String
  cleaningDate  DateTime
  notifiedAt    DateTime?
  status        CleaningStatus @default(PENDING)
  notes         String?
  createdAt     DateTime       @default(now())

  reservation Reservation   @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  staff       CleaningStaff   @relation(fields: [staffId], references: [id], onDelete: Cascade)
  property    Property        @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([reservationId])
  @@index([cleaningDate])
  @@index([staffId])
  @@index([propertyId])
}
